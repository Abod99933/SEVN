# Simple workflow for deploying static content to GitHub Pages
name: Deploy static content to Pages

on:
  # Runs on pushes targeting the default branch
  push:
    branches: ["main"]

  # Allows you to run this workflow manually from the Actions tab
  workflow_dispatch:

# Sets permissions of the GITHUB_TOKEN to allow deployment to GitHub Pages
permissions:
  contents: read
  pages: write
  id-token: write

# Allow only one concurrent deployment, skipping runs queued between the run in-progress and latest queued.
# However, do NOT cancel in-progress runs as we want to allow these production deployments to complete.
concurrency:
  group: "pages"
  cancel-in-progress: false

jobs:
  # Single deploy job since we're just deploying
  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
      - name: Setup Pages
        uses: actions/configure-pages@v5
      - name: Upload artifact
        uses: actions/upload-pages-artifact@v3
        with:
          # Upload entire repository
          path: '.'
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <title>متجر نيترو</title>
  <style>
    body {
      font-family: Arial;
      margin: 0;
      background: #f5f5f5;
      direction: rtl;
    }
    header {
      background: #111;
      color: white;
      padding: 15px;
      text-align: center;
      font-size: 24px;
    }
    .banner {
      width: 100%;
      height: 200px;
      background: url('https://via.placeholder.com/1200x200') no-repeat center/cover;
      position: relative;
      overflow: hidden;
    }
    .banner::after {
      content: '\2728';
      position: absolute;
      top: 50%;
      left: -50px;
      font-size: 50px;
      color: #fff;
      animation: shine 2s linear infinite;
    }
    @keyframes shine {
      0% { left: -50px; opacity: 0; }
      50% { left: 100%; opacity: 1; }
      100% { left: 100%; opacity: 0; }
    }
    .products {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px;
      padding: 20px;
    }
    .product {
      background: white;
      padding: 15px;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      text-align: center;
    }
    .product img {
      width: 100%;
      border-radius: 10px;
    }
    .product h3 { margin: 10px 0; }
    .product button {
      background: #28a745;
      color: white;
      border: none;
      padding: 10px;
      border-radius: 5px;
      cursor: pointer;
    }
    .cart {
      position: fixed;
      top: 10px;
      left: 10px;
      background: #fff;
      padding: 10px;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.2);
    }
    .admin-btn {
      position: fixed;
      top: 10px;
      right: 10px;
      background: #007bff;
      color: white;
      border: none;
      padding: 10px;
      border-radius: 5px;
      cursor: pointer;
    }
    .admin-panel {
      display: none;
      position: fixed;
      top: 50px;
      right: 50px;
      background: #fff;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 0 15px rgba(0,0,0,0.3);
      width: 300px;
      z-index: 1000;
    }
    .admin-panel input, .admin-panel textarea { width: 100%; margin-bottom: 10px; padding: 5px; }
  </style>
</head>
<body>

<header>🛒 متجر نيترو</header>
<div class="banner"></div>

<div class="cart">السلة: <span id="cart-count">0</span></div>
<button class="admin-btn" onclick="loginAdmin()">Admin</button>

<div class="products" id="products">
  <div class="product">
    <img src="https://via.placeholder.com/200">
    <h3 id="prod-name-1">نيترو 1</h3>
    <p id="prod-price-1">100 ريال</p>
    <button onclick="addToCart()">أضف للسلة</button>
  </div>
  <div class="product">
    <img src="https://via.placeholder.com/200">
    <h3 id="prod-name-2">نيترو 2</h3>
    <p id="prod-price-2">150 ريال</p>
    <button onclick="addToCart()">أضف للسلة</button>
  </div>
</div>

<div class="admin-panel" id="admin-panel">
  <h3>لوحة التحكم</h3>
  <label>البنر (رابط صورة):</label>
  <input type="text" id="banner-url">
  <label>اسم المنتج 1:</label>
  <input type="text" id="admin-prod-name-1">
  <label>سعر المنتج 1:</label>
  <input type="text" id="admin-prod-price-1">
  <label>اسم المنتج 2:</label>
  <input type="text" id="admin-prod-name-2">
  <label>سعر المنتج 2:</label>
  <input type="text" id="admin-prod-price-2">
  <button onclick="saveAdmin()">حفظ التغييرات</button>
</div>

<script>
  let count = 0;
  function addToCart() {
    count++;
    document.getElementById("cart-count").innerText = count;
  }

  function loginAdmin() {
    let pass = prompt('أدخل كلمة المرور:');
    if(pass === 'ABOD*966#') {
      document.getElementById('admin-panel').style.display = 'block';
      alert('تم تسجيل الدخول كمدير');
    } else alert('كلمة المرور خاطئة');
  }

  function saveAdmin() {
    let banner = document.getElementById('banner-url').value;
    if(banner) document.querySelector('.banner').style.backgroundImage = `url('${banner}')`;

    let name1 = document.getElementById('admin-prod-name-1').value;
    let price1 = document.getElementById('admin-prod-price-1').value;
    if(name1) document.getElementById('prod-name-1').innerText = name1;
    if(price1) document.getElementById('prod-price-1').innerText = price1;

    let name2 = document.getElementById('admin-prod-name-2').value;
    let price2 = document.getElementById('admin-prod-price-2').value;
    if(name2) document.getElementById('prod-name-2').innerText = name2;
    if(price2) document.getElementById('prod-price-2').innerText = price2;

    alert('تم حفظ التغييرات');
  }
</script>

</body>
</html>
